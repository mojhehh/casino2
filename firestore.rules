rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()  { return request.auth != null; }
    function isMe(uid)   { return signedIn() && request.auth.uid == uid; }
    function isStaff()   {
      return signedIn() &&
        get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role in ['admin','mod'];
    }
    function isAdmin()   {
      return signedIn() &&
        get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'admin';
    }
    function isNum(v)    { return v is number && v >= 0 && v < 1e30; }
    function notTooFast(field) {
      return !(field in resource.data) ||
             request.time > resource.data[field] + duration.value(500, 'ms');
    }

    match /staff/{uid} {
      allow read:  if signedIn();
      allow write: if isAdmin();
    }

    match /players/{uid} {
      allow read: if signedIn();

      allow create: if isMe(uid)
        && request.resource.data.balance == 1000
        && request.resource.data.uid == uid;

      allow update: if isMe(uid)
        && request.resource.data.uid == resource.data.uid
        && isNum(request.resource.data.balance)
        && (
             request.resource.data.balance <= resource.data.balance + 1e15 ||
             isStaff()
           );

      allow delete: if isAdmin();
    }

    match /usernames/{name} {
      allow read:  if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /presence/{uid} {
      allow read:  if signedIn();
      allow write: if isMe(uid);
    }

    match /chat/{msgId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 500
        && request.resource.data.ts is number;
      allow update: if false;
      allow delete: if isStaff() ||
        (signedIn() && resource.data.uid == request.auth.uid);
    }

    match /casino/{doc=**} {
      allow read:  if true;
      allow write: if isStaff();
    }

    match /bannedUsers/{uid} { allow read: if true; allow write: if isStaff(); }
    match /mutedUsers/{uid}  { allow read: if true; allow write: if isStaff(); }
    match /warnings/{uid}    { allow read: if isMe(uid) || isStaff(); allow write: if isStaff(); }

    match /admin/{doc=**}    { allow read: if signedIn(); allow write: if isAdmin(); }

    match /bugReports/{id} {
      allow read:   if isStaff() ||
        (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    match /duelRooms/{code} {
      allow read:   if signedIn();
      allow create: if signedIn()
        && request.resource.data.host == request.auth.uid;
      allow update: if signedIn();
      allow delete: if signedIn() && (
        resource.data.host == request.auth.uid ||
        resource.data.guest == request.auth.uid ||
        isStaff()
      );
    }

    match /rrGames/{id}  { allow read: if signedIn(); allow write: if signedIn(); }
    match /bsrGames/{id} { allow read: if signedIn(); allow write: if signedIn(); }
    match /liveTrades/{id} { allow read: if signedIn(); allow write: if signedIn(); }

    match /storeListings/{id} {
      allow read:   if true;
      allow create: if signedIn()
        && request.resource.data.seller == request.auth.uid;
      allow update: if signedIn();
      allow delete: if signedIn() &&
        (resource.data.seller == request.auth.uid || isStaff());
    }
    match /storeSales/{id} {
      allow read:   if signedIn();
      allow create: if signedIn();
      allow update: if false;
      allow delete: if isStaff();
    }

    match /limitedCases/current {
      allow read:   if true;
      allow create: if signedIn();
      allow update: if signedIn()
        && request.resource.data.id == resource.data.id
        && request.resource.data.remaining == resource.data.remaining - 1
        && request.resource.data.remaining >= 0;
      allow delete: if isStaff();
    }

    match /trades/{uid}/incoming/{id} {
      allow read:   if isMe(uid) || isStaff();
      // any authenticated user can SEND an incoming trade to another player.
      // cash field must be a non-negative number (no upper cap).
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && (
             !('cash' in request.resource.data) ||
             (request.resource.data.cash is number &&
              request.resource.data.cash >= 0)
           );
      allow update: if false;
      allow delete: if isMe(uid) || isStaff();
    }
    match /tradeRequests/{uid}/items/{id} {
      allow read:   if isMe(uid) || isStaff();
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid;
      // recipient may write a "response" field
      allow update: if isMe(uid) || isStaff();
      allow delete: if signedIn();
    }
    match /pendingRefunds/{uid}/items/{id} {
      allow read:   if isMe(uid) || isStaff();
      // refunds are written by the player who DECLINED a trade (returning the
      // sender's items). cash field must be non-negative.
      allow create: if signedIn()
        && (!('cash' in request.resource.data) ||
            (request.resource.data.cash is number &&
             request.resource.data.cash >= 0));
      allow update: if false;
      allow delete: if isMe(uid) || isStaff();
    }
    match /dms/{thread}/messages/{id} {
      allow read:   if signedIn();
      allow create: if signedIn()
        && request.resource.data.from == request.auth.uid;
      allow delete: if isStaff();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
